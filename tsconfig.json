{
  "compilerOptions": {
    "outDir": "./dist/",
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "es5",
    "lib": ["dom", "es2016"],
    "baseUrl": "",
    "paths": {
      "webpack": ["node_modules/@types/webpack/index.d.ts"],
      "filemanager-webpack-plugin": [
        "node_modules/filemanager-webpack-plugin/types.d.ts"
      ]
    },
    "esModuleInterop": true
  },
  "include": ["./src/**/*.ts"]
}
